# GitHub SEO Pipeline Example Environment File
# Copy this to .env to configure your local setup

# ------------------------------------------------------------------
# LLM Generator Configuration
# ------------------------------------------------------------------

# Primary generator provider. Choices: rule_based | local_model | openai
GENERATOR_PROVIDER=rule_based

# The provider to fallback to if the primary one fails.
GENERATOR_FALLBACK_PROVIDER=rule_based

# ------------------------------------------------------------------
# Local Model (Ollama) Settings
# ------------------------------------------------------------------

# The URL where your local Ollama instance is running.
OLLAMA_API_URL=http://localhost:11434/api/generate

# Recommended models: llama3.1:8b or mistral:7b
# NOTE: Make sure you have pulled this model locally using `ollama pull model_name`
OLLAMA_MODEL=llama3.1:8b

# ------------------------------------------------------------------
# External Services
# ------------------------------------------------------------------

# GitHub Token for increasing API limits. (Highly Recommended)
GITHUB_TOKEN=your_github_token_here

# OpenAI API Key (Only needed if GENERATOR_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
